+    hash[1] = X509_NAME_hash_old(name); /* MD5 name hash */
+    valid_hash[1] = 1;
+#else
+    valid_hash[1] = 0;
+#endif
+    for (l = 0; l < 2; ++l) {
+        h = hash[l];
+        if (valid_hash[l] == 0)
+            continue; /* skip invalid hash */
